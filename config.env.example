# ============================================================================
# AutoTrader — Configuration File
# ============================================================================
# Copy this file to config.env and fill in your values.
# NEVER commit config.env to version control.
# ============================================================================

# ----------------------------------------------------------------------------
# TELEGRAM LISTENER (Telethon — user account, not bot)
# ----------------------------------------------------------------------------
# Get these from https://my.telegram.org/apps
# 1. Log in with your phone number
# 2. Click "API development tools"
# 3. Create a new application (any name/platform)
# 4. Copy the api_id (integer) and api_hash (hex string)
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=abcdef1234567890abcdef1234567890

# Your phone number in international format (used for first-time auth only)
TELEGRAM_PHONE=+1234567890

# The channel to monitor. Use the numeric channel ID (negative number).
# To find it: forward a message from the channel to @userinfobot on Telegram.
# Alternatively, use the channel username without @, e.g. "gold_signals_vip"
TELEGRAM_CHANNEL_ID=-1001234567890

# Path to store the Telethon session file (relative to project root)
TELEGRAM_SESSION_PATH=data/autotrader.session

# ----------------------------------------------------------------------------
# NOTIFICATION BOT (separate Telegram bot for sending YOU alerts)
# ----------------------------------------------------------------------------
# Create a bot via @BotFather on Telegram and copy the token.
# Then message the bot and get your chat ID from @userinfobot.
NOTIFY_BOT_TOKEN=7000000000:AAF-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTIFY_CHAT_ID=123456789

# ----------------------------------------------------------------------------
# AI SIGNAL PARSER — PRIMARY: Google Gemini
# ----------------------------------------------------------------------------
# Get your free API key from https://aistudio.google.com/apikey
# Free tier: ~15 requests/min, ~1500 requests/day
GEMINI_API_KEY=AIzaSy-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Model to use (gemini-2.0-flash is fast and free-tier eligible)
GEMINI_MODEL=gemini-2.0-flash

# ----------------------------------------------------------------------------
# AI SIGNAL PARSER — FAILOVER: Groq
# ----------------------------------------------------------------------------
# Get your free API key from https://console.groq.com/keys
# Free tier: ~30 requests/min, ~14400 requests/day for smaller models
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Model to use (llama-3.3-70b-versatile is powerful and free-tier eligible)
GROQ_MODEL=llama-3.3-70b-versatile

# ----------------------------------------------------------------------------
# METATRADER 5 CONNECTION (via mt5linux bridge)
# ----------------------------------------------------------------------------
# The mt5linux RPC bridge host/port (should be localhost on same server)
MT5_HOST=localhost
MT5_PORT=18812

# Your Alpari MT5 account credentials
# Find on your Alpari personal area → Accounts → MT5 account details
MT5_ACCOUNT=12345678
MT5_PASSWORD=YourMT5Password
MT5_SERVER=Alpari-MT5

# ----------------------------------------------------------------------------
# TRADING PARAMETERS
# ----------------------------------------------------------------------------
# Symbol to trade. The executor will auto-detect the broker's suffix.
# Common Alpari variants: XAUUSD, XAUUSDm, XAUUSD., XAUUSD#
SYMBOL=XAUUSD

# Magic number: unique integer identifying this bot's orders.
# Prevents interference with manual trades or other EAs.
# Use any number 100000-999999 that isn't used elsewhere.
MAGIC_NUMBER=240001

# Default lot size if signal doesn't specify one and risk-based
# calculation is not possible (e.g., missing SL).
DEFAULT_LOT_SIZE=0.01

# Maximum allowed lot size per single order (safety cap)
MAX_LOT_SIZE=1.0

# Minimum lot size (broker minimum, Alpari typically 0.01)
MIN_LOT_SIZE=0.01

# Lot step (Alpari typically 0.01)
LOT_STEP=0.01

# Maximum allowed slippage in points when placing orders.
# XAUUSD: 1 point = $0.01. Slippage of 50 = $0.50 max price deviation.
MAX_SLIPPAGE_POINTS=50

# ----------------------------------------------------------------------------
# RISK MANAGEMENT
# ----------------------------------------------------------------------------
# Maximum risk per trade as percentage of account balance (e.g., 1.0 = 1%)
# Lot size is auto-calculated so that hitting SL loses at most this %.
MAX_RISK_PER_TRADE_PCT=1.0

# Maximum number of concurrent open positions
MAX_OPEN_TRADES=5

# Daily loss limit as percentage of starting-of-day balance.
# If daily losses exceed this, the bot stops opening new trades until next day.
DAILY_LOSS_LIMIT_PCT=5.0

# Signal expiry in minutes. Signals older than this are discarded.
# Prevents acting on stale signals after bot restart or downtime.
SIGNAL_EXPIRY_MINUTES=30

# Deduplication window in hours. Same signal won't be executed twice
# within this window. Matching is based on action+entry+SL+TP hash.
DEDUP_WINDOW_HOURS=4

# ----------------------------------------------------------------------------
# OPERATION MODE
# ----------------------------------------------------------------------------
# Set to true to run in dry-run mode:
# - Parses signals normally
# - Calculates lot sizes and risk
# - Logs all intended actions
# - Does NOT place any real trades
DRY_RUN=true

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log file path (relative to project root)
LOG_FILE_PATH=data/autotrader.log

# Maximum log file size in MB before rotation
LOG_MAX_SIZE_MB=10

# Number of rotated log files to keep
LOG_BACKUP_COUNT=5

# Database file path (relative to project root)
DATABASE_PATH=data/autotrader.db

# Health check HTTP server port (set to 0 to disable)
HEALTH_CHECK_PORT=8080
